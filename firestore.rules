rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Diário Climático — leitura pública, escrita restrita ao UID do dono ===
    match /leituras/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.uid == "IKgOWOLPuCRMvKNur6OH4fiE9ng1";
      allow delete: if resource.data.uid == "IKgOWOLPuCRMvKNur6OH4fiE9ng1";
    }
    match /chuvas/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.uid == "IKgOWOLPuCRMvKNur6OH4fiE9ng1";
      allow delete: if resource.data.uid == "IKgOWOLPuCRMvKNur6OH4fiE9ng1";
    }

    // === Sistema de Medição de Leite — requer autenticação ===
    match /leite_competencias/{doc=**} { allow read, write: if request.auth != null; }
    match /leite_setores/{doc=**}      { allow read, write: if request.auth != null; }
    match /leite_tipos/{doc=**}        { allow read, write: if request.auth != null; }
    match /leite_clientes/{doc=**}     { allow read, write: if request.auth != null; }
    match /leite_medicoes/{doc=**}     { allow read, write: if request.auth != null; }
  }
}
